{
  "name": "newax-core",
  "version": "0.0.0",
  "private": true,
  "description": "Private monorepo foundation for reusable NEWAX business infrastructure.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.11.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "clean": "pnpm -r --if-present run clean",
    "dev": "pnpm -r --parallel --if-present run dev",
    "format": "pnpm -r --if-present run format",
    "format:check": "pnpm -r --if-present run format:check",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
