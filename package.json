{
  "name": "newax-core",
  "version": "0.0.0",
  "private": true,
  "description": "Private monorepo foundation for reusable NEWAX business infrastructure.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.11.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "clean": "pnpm -r --if-present run clean",
    "dev": "pnpm -r --parallel --if-present run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "learning:flush": "node tooling/flush-engineering-events.mjs",
    "learning:record": "node tooling/record-engineering-event.mjs",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "operation:validate": "node tooling/validate-operation-intent.mjs",
    "test": "pnpm test:learning && pnpm -r --if-present run test",
    "test:learning": "node --test tooling/engineering-learning-core.test.mjs tooling/workflow-failure-intake-controls.test.mjs",
    "typecheck": "pnpm -r --if-present run typecheck",
    "verify": "node tooling/run-engineering-command.mjs -- pnpm verify:raw",
    "verify:raw": "pnpm format:check && pnpm verify:workflow-intake && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:workflow-intake": "node tooling/workflow-failure-intake-controls.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "globals": "17.7.0",
    "prettier": "3.9.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
