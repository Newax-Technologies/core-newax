{
  "name": "newax-core",
  "version": "0.0.0",
  "private": true,
  "description": "Private monorepo foundation for reusable NEWAX business infrastructure.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.11.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "clean": "pnpm -r --if-present run clean",
    "dev": "pnpm -r --parallel --if-present run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "globals": "17.7.0",
    "prettier": "3.9.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
