# Normalize text files and use LF in the repository.
* text=auto eol=lf

# Text formats.
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.graphql text eol=lf
*.gql text eol=lf
*.prisma text eol=lf
*.sql text eol=lf
*.env text eol=lf
*.example text eol=lf

# Source code and scripts.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf

# Windows command files require CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Lockfiles are generated and should not receive manual merge treatment.
pnpm-lock.yaml text eol=lf linguist-generated=true
package-lock.json text eol=lf linguist-generated=true
yarn.lock text eol=lf linguist-generated=true

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.7z binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.mov binary
*.avi binary
*.webm binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# Preserve source maps as text when committed deliberately.
*.map text eol=lf
