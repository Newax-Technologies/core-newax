{
  "registry_name": "NEWAX Module Registry",
  "registry_key": "newax-module-registry",
  "registry_version": "0.1.2",
  "registry_status": "draft",
  "last_updated": "2026-07-11",
  "owner": "NEWAX Engineering",
  "purpose": "Internal source of truth for planned, draft, active, deprecated, replaced, and archived NEWAX modules.",
  "governance": {
    "architecture_model": "modular_monolith_first",
    "versioning": "semantic_versioning",
    "approval_standard": "docs/standards/module-approval-checklist.md",
    "module_standard": "docs/standards/module-standard.md",
    "registry_standard": "docs/standards/module-registry-standard.md",
    "important_note": "A registry entry tracks a module. It does not approve the module for production use. Only modules with active status and completed approval may be reused in client systems."
  },
  "modules": [
    {
      "module_name": "People",
      "module_key": "people",
      "module_layer": "foundation",
      "module_version": "0.1.0",
      "module_status": "draft",
      "module_owner": "NEWAX Engineering",
      "description": "Maintains one central record for each real person across NEWAX project domains.",
      "dependencies": [],
      "required_permissions": [
        "people.view",
        "people.create",
        "people.update",
        "people.archive",
        "people.identifiers.view",
        "people.identifiers.manage"
      ],
      "exposed_events": [
        "person.created",
        "person.updated",
        "person.archived",
        "person.identifier_added",
        "person.identifier_verified"
      ],
      "consumed_events": [],
      "configuration_options": ["person_status_values", "identity_deduplication_policy"],
      "database_ownership": ["core_people", "core_person_identifiers"],
      "tenant_scope": "mixed_global_and_organization_context",
      "documentation_path": "packages/people/README.md",
      "changelog_path": "packages/people/CHANGELOG.md",
      "compatibility_notes": "Shared identity foundation. Domain modules must reference people through person_id instead of duplicating identity data."
    },
    {
      "module_name": "Organizations",
