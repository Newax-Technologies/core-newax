generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
  engineType   = "client"
}

datasource db {
  provider = "postgresql"
}

model CoreTenant {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  status    String    @default("active") @db.VarChar(32)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  organizations             CoreOrganization[]
  organizationRelationships CoreOrganizationRelationship[]
  personRelationships       CorePersonRelationship[]
  peopleIntakes             CorePeopleIntake[]
  objects                   CoreObject[]
  files                     CoreFile[]
  auditLogs                 CoreAuditLog[]
  externalReferences        CoreExternalReference[]

  @@index([status])
  @@index([name])
  @@map("core_tenants")
}

model CoreOrganization {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  parentOrganizationId String?   @map("parent_organization_id") @db.Uuid
  legalName            String    @map("legal_name") @db.VarChar(255)
  displayName          String    @map("display_name") @db.VarChar(255)
  organizationType     String    @map("organization_type") @db.VarChar(64)
  registrationNumber   String?   @map("registration_number") @db.VarChar(128)
  taxNumber            String?   @map("tax_number") @db.VarChar(128)
  status               String    @default("active") @db.VarChar(32)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant                CoreTenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  parentOrganization    CoreOrganization?               @relation("OrganizationHierarchy", fields: [tenantId, parentOrganizationId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade)
  childOrganizations    CoreOrganization[]              @relation("OrganizationHierarchy")
  sourceRelationships   CoreOrganizationRelationship[]  @relation("OrganizationRelationshipSource")
  targetRelationships   CoreOrganizationRelationship[]  @relation("OrganizationRelationshipTarget")
  memberships           CoreMembership[]
  roles                 CoreRole[]
  organizationContacts  CoreOrganizationContactMethod[]
  organizationAddresses CoreOrganizationAddress[]
  ownedObjects          CoreObject[]                    @relation("ObjectOwningOrganization")
  files                 CoreFile[]
  auditLogs             CoreAuditLog[]
  externalReferences    CoreExternalReference[]
  peopleIntakes         CorePeopleIntake[]

  @@unique([tenantId, id])
  @@index([tenantId, parentOrganizationId])
  @@index([tenantId, organizationType, status])
  @@index([tenantId, displayName])
  @@map("core_organizations")
}

model CoreOrganizationRelationship {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  sourceOrganizationId String    @map("source_organization_id") @db.Uuid
  targetOrganizationId String    @map("target_organization_id") @db.Uuid
  relationshipType     String    @map("relationship_type") @db.VarChar(64)
  status               String    @default("active") @db.VarChar(32)
  validFrom            DateTime? @map("valid_from") @db.Date
  validUntil           DateTime? @map("valid_until") @db.Date
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant             CoreTenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sourceOrganization CoreOrganization @relation("OrganizationRelationshipSource", fields: [tenantId, sourceOrganizationId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade)
  targetOrganization CoreOrganization @relation("OrganizationRelationshipTarget", fields: [tenantId, targetOrganizationId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId, sourceOrganizationId, relationshipType, status])
  @@index([tenantId, targetOrganizationId, relationshipType, status])
  @@map("core_organization_relationships")
}

model CorePerson {
  id            String    @id @default(uuid()) @db.Uuid
  firstName     String    @map("first_name") @db.VarChar(128)
  middleName    String?   @map("middle_name") @db.VarChar(128)
  lastName      String    @map("last_name") @db.VarChar(128)
  preferredName String?   @map("preferred_name") @db.VarChar(128)
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date
  gender        String?   @db.VarChar(32)
  status        String    @default("active") @db.VarChar(32)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  identifiers         CorePersonIdentifier[]
  user                CoreUser?
  memberships         CoreMembership[]
  personContacts      CorePersonContactMethod[]
  personAddresses     CorePersonAddress[]
  sourceRelationships CorePersonRelationship[]  @relation("PersonRelationshipSource")
  targetRelationships CorePersonRelationship[]  @relation("PersonRelationshipTarget")

  @@index([lastName, firstName])
  @@index([status])
  @@map("core_people")
}

model CorePersonIdentifier {
  id                 String    @id @default(uuid()) @db.Uuid
  personId           String    @map("person_id") @db.Uuid
  identifierType     String    @map("identifier_type") @db.VarChar(64)
  identifierValue    String    @map("identifier_value") @db.VarChar(255)
  issuingAuthority   String?   @map("issuing_authority") @db.VarChar(255)
  issuingCountryCode String?   @map("issuing_country_code") @db.Char(2)
  validFrom          DateTime? @map("valid_from") @db.Date
  validUntil         DateTime? @map("valid_until") @db.Date
  isVerified         Boolean   @default(false) @map("is_verified")
  verifiedAt         DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  person CorePerson @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([personId, identifierType, identifierValue])
  @@index([identifierType, identifierValue])
  @@map("core_person_identifiers")
}

model CorePersonRelationship {
  id                           String    @id @default(uuid()) @db.Uuid
  tenantId                     String    @map("tenant_id") @db.Uuid
  sourcePersonId               String    @map("source_person_id") @db.Uuid
  targetPersonId               String    @map("target_person_id") @db.Uuid
  relationshipType             String    @map("relationship_type") @db.VarChar(64)
  relationshipRole             String    @default("unspecified") @map("relationship_role") @db.VarChar(64)
  relationshipBasis            String    @default("unspecified") @map("relationship_basis") @db.VarChar(64)
  status                       String    @default("active") @db.VarChar(32)
  validFrom                    DateTime? @map("valid_from") @db.Date
  validUntil                   DateTime? @map("valid_until") @db.Date
  isVerified                   Boolean   @default(false) @map("is_verified")
  verifiedAt                   DateTime? @map("verified_at") @db.Timestamptz(6)
  verifiedByUserId             String?   @map("verified_by_user_id") @db.Uuid
  verificationSource           String?   @map("verification_source") @db.VarChar(128)
  verificationRevokedAt        DateTime? @map("verification_revoked_at") @db.Timestamptz(6)
  verificationRevokedByUserId  String?   @map("verification_revoked_by_user_id") @db.Uuid
  verificationRevocationReason String?   @map("verification_revocation_reason") @db.VarChar(1000)
  sourceReference              String?   @map("source_reference") @db.VarChar(255)
  version                      Int       @default(1)
  createdAt                    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                    CoreTenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sourcePerson              CorePerson @relation("PersonRelationshipSource", fields: [sourcePersonId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  targetPerson              CorePerson @relation("PersonRelationshipTarget", fields: [targetPersonId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  verifiedByUser            CoreUser?  @relation("PersonRelationshipVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  verificationRevokedByUser CoreUser?  @relation("PersonRelationshipVerificationRevokedBy", fields: [verificationRevokedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Self-links, validity, verification consistency, active-link uniqueness, and
  // active parentage cycles are enforced by migration-owned PostgreSQL constraints.
  @@index([tenantId, sourcePersonId, relationshipType, status])
  @@index([tenantId, targetPersonId, relationshipType, status])
  @@index([verifiedByUserId])
  @@index([verificationRevokedByUserId])
  @@map("core_person_relationships")
}

model CorePeopleIntake {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  title             String    @db.VarChar(128)
  sourceType        String    @map("source_type") @db.VarChar(64)
  sourceReference   String?   @map("source_reference") @db.VarChar(255)
  status            String    @default("draft") @db.VarChar(32)
  payload           Json      @db.JsonB
  personCount       Int       @map("person_count")
  relationshipCount Int       @map("relationship_count")
  version           Int       @default(1)
  createdByUserId   String    @map("created_by_user_id") @db.Uuid
  submittedAt       DateTime? @map("submitted_at") @db.Timestamptz(6)
  reviewedAt        DateTime? @map("reviewed_at") @db.Timestamptz(6)
  reviewedByUserId  String?   @map("reviewed_by_user_id") @db.Uuid
  reviewDecision    String?   @map("review_decision") @db.VarChar(16)
  reviewNotes       String?   @map("review_notes") @db.VarChar(2000)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant         CoreTenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization   CoreOrganization @relation(fields: [tenantId, organizationId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade)
  createdByUser  CoreUser         @relation("PeopleIntakeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviewedByUser CoreUser?        @relation("PeopleIntakeReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Workflow state, four-eye review, immutable submission, payload shape,
  // and transition integrity are enforced by migration-owned PostgreSQL constraints.
  @@index([tenantId, organizationId, status, submittedAt, id])
  @@index([createdByUserId, status])
  @@index([reviewedByUserId, reviewedAt])
  @@map("core_people_intakes")
}

model CoreUser {
  id          String    @id @default(uuid()) @db.Uuid
  personId    String    @unique @map("person_id") @db.Uuid
  status      String    @default("invited") @db.VarChar(32)
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(6)
  lockedUntil DateTime? @map("locked_until") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  person                                 CorePerson                  @relation(fields: [personId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  identities                             CoreUserIdentity[]
  credentials                            CoreUserCredential[]
  sessions                               CoreUserSession[]
  authenticationAttempts                 CoreAuthenticationAttempt[]
  rolePermissionsCreated                 CoreRolePermission[]        @relation("RolePermissionCreatedBy")
  membershipRolesAssigned                CoreMembershipRole[]        @relation("MembershipRoleAssignedBy")
  membershipRolesRevoked                 CoreMembershipRole[]        @relation("MembershipRoleRevokedBy")
  objectAssignmentsCreated               CoreObjectAssignment[]      @relation("ObjectAssignmentCreatedBy")
  filesCreated                           CoreFile[]                  @relation("FileCreatedBy")
  auditLogs                              CoreAuditLog[]              @relation("AuditActor")
  personRelationshipsVerified            CorePersonRelationship[]    @relation("PersonRelationshipVerifiedBy")
  personRelationshipVerificationsRevoked CorePersonRelationship[]    @relation("PersonRelationshipVerificationRevokedBy")
  peopleIntakesCreated                   CorePeopleIntake[]          @relation("PeopleIntakeCreatedBy")
  peopleIntakesReviewed                  CorePeopleIntake[]          @relation("PeopleIntakeReviewedBy")

  @@index([status])
  @@map("core_users")
}

model CoreUserIdentity {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  identityType    String    @map("identity_type") @db.VarChar(32)
  identityValue   String    @map("identity_value") @db.VarChar(320)
  normalizedValue String    @map("normalized_value") @db.VarChar(320)
  isPrimary       Boolean   @default(false) @map("is_primary")
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([identityType, normalizedValue])
  @@index([userId, isPrimary])
  @@map("core_user_identities")
}

model CoreUserCredential {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  credentialType String    @map("credential_type") @db.VarChar(32)
  secretHash     String    @map("secret_hash") @db.Text
  status         String    @default("active") @db.VarChar(32)
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz(6)
  lastUsedAt     DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, credentialType])
  @@index([userId, credentialType, status])
  @@map("core_user_credentials")
}

model CoreUserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash") @db.VarChar(128)
  status           String    @default("active") @db.VarChar(32)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.Text
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  lastSeenAt       DateTime? @map("last_seen_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, status, expiresAt])
  @@map("core_user_sessions")
}

model CoreAuthenticationAttempt {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String?  @map("user_id") @db.Uuid
  identityFingerprint String   @map("identity_fingerprint") @db.Char(64)
  outcome             String   @db.VarChar(64)
  ipAddress           String?  @map("ip_address") @db.VarChar(64)
  userAgent           String?  @map("user_agent") @db.Text
  occurredAt          DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  user CoreUser? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId, occurredAt])
  @@index([identityFingerprint, occurredAt])
  @@index([outcome, occurredAt])
  @@map("core_authentication_attempts")
}

model CoreMembership {
  id              String    @id @default(uuid()) @db.Uuid
  personId        String    @map("person_id") @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  membershipType  String    @map("membership_type") @db.VarChar(64)
  referenceNumber String?   @map("reference_number") @db.VarChar(128)
  jobTitle        String?   @map("job_title") @db.VarChar(128)
  status          String    @default("active") @db.VarChar(32)
  startDate       DateTime? @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  person            CorePerson             @relation(fields: [personId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization      CoreOrganization       @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  membershipRoles   CoreMembershipRole[]
  objectAssignments CoreObjectAssignment[]

  @@index([personId, status])
  @@index([organizationId, membershipType, status])
  @@map("core_memberships")
}

model CoreRole {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  code           String   @db.VarChar(128)
  name           String   @db.VarChar(128)
  description    String?  @db.Text
  roleType       String   @map("role_type") @db.VarChar(32)
  status         String   @default("active") @db.VarChar(32)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization    CoreOrganization?    @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  rolePermissions CoreRolePermission[]
  membershipRoles CoreMembershipRole[]

  @@unique([organizationId, code])
  @@index([roleType, status])
  @@map("core_roles")
}

model CorePermission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(160)
  moduleCode  String   @map("module_code") @db.VarChar(64)
  resource    String   @db.VarChar(96)
  action      String   @db.VarChar(64)
  riskLevel   String   @default("standard") @map("risk_level") @db.VarChar(32)
  description String?  @db.Text
  status      String   @default("active") @db.VarChar(32)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions CoreRolePermission[]

  @@index([moduleCode, resource, action])
  @@index([status])
  @@map("core_permissions")
}

model CoreRolePermission {
  roleId          String   @map("role_id") @db.Uuid
  permissionId    String   @map("permission_id") @db.Uuid
  effect          String   @default("allow") @db.VarChar(16)
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role          CoreRole       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission    CorePermission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdByUser CoreUser?      @relation("RolePermissionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("core_role_permissions")
}

model CoreMembershipRole {
  id               String    @id @default(uuid()) @db.Uuid
  membershipId     String    @map("membership_id") @db.Uuid
  roleId           String    @map("role_id") @db.Uuid
  assignedByUserId String?   @map("assigned_by_user_id") @db.Uuid
  revokedByUserId  String?   @map("revoked_by_user_id") @db.Uuid
  validFrom        DateTime  @default(now()) @map("valid_from") @db.Timestamptz(6)
  validUntil       DateTime? @map("valid_until") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  membership     CoreMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role           CoreRole       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  assignedByUser CoreUser?      @relation("MembershipRoleAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  revokedByUser  CoreUser?      @relation("MembershipRoleRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([membershipId, validUntil, revokedAt])
  @@index([roleId])
  @@map("core_membership_roles")
}

model CoreContactMethod {
  id              String    @id @default(uuid()) @db.Uuid
  contactType     String    @map("contact_type") @db.VarChar(32)
  contactValue    String    @map("contact_value") @db.VarChar(320)
  normalizedValue String    @map("normalized_value") @db.VarChar(320)
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  personContacts       CorePersonContactMethod[]
  organizationContacts CoreOrganizationContactMethod[]

  @@unique([contactType, normalizedValue])
  @@map("core_contact_methods")
}

model CorePersonContactMethod {
  id              String    @id @default(uuid()) @db.Uuid
  personId        String    @map("person_id") @db.Uuid
  contactMethodId String    @map("contact_method_id") @db.Uuid
  label           String?   @db.VarChar(64)
  isPrimary       Boolean   @default(false) @map("is_primary")
  status          String    @default("active") @db.VarChar(32)
  validFrom       DateTime? @map("valid_from") @db.Date
  validUntil      DateTime? @map("valid_until") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  person        CorePerson        @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  contactMethod CoreContactMethod @relation(fields: [contactMethodId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([personId, contactMethodId, label])
  @@index([personId, isPrimary, status])
  @@map("core_person_contact_methods")
}

model CoreOrganizationContactMethod {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  contactMethodId String    @map("contact_method_id") @db.Uuid
  label           String?   @db.VarChar(64)
  isPrimary       Boolean   @default(false) @map("is_primary")
  status          String    @default("active") @db.VarChar(32)
  validFrom       DateTime? @map("valid_from") @db.Date
  validUntil      DateTime? @map("valid_until") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization  CoreOrganization  @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  contactMethod CoreContactMethod @relation(fields: [contactMethodId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([organizationId, contactMethodId, label])
  @@index([organizationId, isPrimary, status])
  @@map("core_organization_contact_methods")
}

model CoreAddress {
  id          String   @id @default(uuid()) @db.Uuid
  line1       String   @map("line_1") @db.VarChar(255)
  line2       String?  @map("line_2") @db.VarChar(255)
  locality    String?  @db.VarChar(128)
  city        String   @db.VarChar(128)
  district    String?  @db.VarChar(128)
  province    String?  @db.VarChar(128)
  postalCode  String?  @map("postal_code") @db.VarChar(32)
  countryCode String   @map("country_code") @db.Char(2)
  latitude    Decimal? @db.Decimal(9, 6)
  longitude   Decimal? @db.Decimal(9, 6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  personAddresses       CorePersonAddress[]
  organizationAddresses CoreOrganizationAddress[]
  objectAddresses       CoreObjectAddress[]

  @@index([countryCode, province, city])
  @@map("core_addresses")
}

model CorePersonAddress {
  id          String    @id @default(uuid()) @db.Uuid
  personId    String    @map("person_id") @db.Uuid
  addressId   String    @map("address_id") @db.Uuid
  addressType String    @map("address_type") @db.VarChar(32)
  label       String?   @db.VarChar(64)
  isPrimary   Boolean   @default(false) @map("is_primary")
  status      String    @default("active") @db.VarChar(32)
  validFrom   DateTime? @map("valid_from") @db.Date
  validUntil  DateTime? @map("valid_until") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  person  CorePerson  @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  address CoreAddress @relation(fields: [addressId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([personId, addressId, addressType])
  @@index([personId, isPrimary, status])
  @@map("core_person_addresses")
}

model CoreOrganizationAddress {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  addressId      String    @map("address_id") @db.Uuid
  addressType    String    @map("address_type") @db.VarChar(32)
  label          String?   @db.VarChar(64)
  isPrimary      Boolean   @default(false) @map("is_primary")
  status         String    @default("active") @db.VarChar(32)
  validFrom      DateTime? @map("valid_from") @db.Date
  validUntil     DateTime? @map("valid_until") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization CoreOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  address      CoreAddress      @relation(fields: [addressId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Active-link uniqueness is enforced by a migration-owned partial index so
  // removed links remain immutable history and do not block a later active link.
  @@index([organizationId, isPrimary, status])
  @@map("core_organization_addresses")
}

model CoreObjectType {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(96)
  name        String   @db.VarChar(128)
  category    String?  @db.VarChar(96)
  description String?  @db.Text
  status      String   @default("active") @db.VarChar(32)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  objects CoreObject[]

  @@index([category, status])
  @@map("core_object_types")
}

model CoreObject {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  objectTypeId         String    @map("object_type_id") @db.Uuid
  owningOrganizationId String    @map("owning_organization_id") @db.Uuid
  parentObjectId       String?   @map("parent_object_id") @db.Uuid
  name                 String    @db.VarChar(255)
  referenceCode        String?   @map("reference_code") @db.VarChar(128)
  serialNumber         String?   @map("serial_number") @db.VarChar(128)
  status               String    @default("active") @db.VarChar(32)
  description          String?   @db.Text
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant             CoreTenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  objectType         CoreObjectType         @relation(fields: [objectTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  owningOrganization CoreOrganization       @relation("ObjectOwningOrganization", fields: [tenantId, owningOrganizationId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade)
  parentObject       CoreObject?            @relation("ObjectHierarchy", fields: [tenantId, parentObjectId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade)
  childObjects       CoreObject[]           @relation("ObjectHierarchy")
  assignments        CoreObjectAssignment[]
  objectAddresses    CoreObjectAddress[]

  @@unique([tenantId, id])
  @@unique([owningOrganizationId, referenceCode])
  @@index([tenantId, owningOrganizationId, objectTypeId, status])
  @@index([tenantId, parentObjectId])
  @@map("core_objects")
}

model CoreObjectAssignment {
  id               String    @id @default(uuid()) @db.Uuid
  objectId         String    @map("object_id") @db.Uuid
  membershipId     String    @map("membership_id") @db.Uuid
  assignmentType   String    @map("assignment_type") @db.VarChar(64)
  status           String    @default("active") @db.VarChar(32)
  validFrom        DateTime  @default(now()) @map("valid_from") @db.Timestamptz(6)
  validUntil       DateTime? @map("valid_until") @db.Timestamptz(6)
  assignedByUserId String?   @map("assigned_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  object         CoreObject     @relation(fields: [objectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  membership     CoreMembership @relation(fields: [membershipId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignedByUser CoreUser?      @relation("ObjectAssignmentCreatedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([objectId, status, validUntil])
  @@index([membershipId, status])
  @@map("core_object_assignments")
}

model CoreObjectAddress {
  id          String    @id @default(uuid()) @db.Uuid
  objectId    String    @map("object_id") @db.Uuid
  addressId   String    @map("address_id") @db.Uuid
  addressType String    @map("address_type") @db.VarChar(32)
  isPrimary   Boolean   @default(false) @map("is_primary")
  status      String    @default("active") @db.VarChar(32)
  validFrom   DateTime? @map("valid_from") @db.Date
  validUntil  DateTime? @map("valid_until") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  object  CoreObject  @relation(fields: [objectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  address CoreAddress @relation(fields: [addressId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([objectId, addressId, addressType])
  @@index([objectId, isPrimary, status])
  @@map("core_object_addresses")
}

model CoreFile {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  storageProvider String   @map("storage_provider") @db.VarChar(64)
  storageKey      String   @map("storage_key") @db.Text
  fileName        String   @map("file_name") @db.VarChar(255)
  mimeType        String   @map("mime_type") @db.VarChar(255)
  fileSize        BigInt   @map("file_size")
  checksum        String   @db.VarChar(128)
  status          String   @default("active") @db.VarChar(32)
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        CoreTenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization  CoreOrganization @relation(fields: [tenantId, organizationId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade)
  createdByUser CoreUser?        @relation("FileCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([tenantId, id])
  @@unique([storageProvider, storageKey])
  @@index([tenantId, organizationId, status, createdAt])
  @@map("core_files")
}

model CoreHttpRateLimitBucket {
  keyHash      String   @id @map("key_hash") @db.Char(64)
  requestCount Int      @default(0) @map("request_count")
  resetAt      DateTime @map("reset_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([resetAt])
  @@map("core_http_rate_limit_buckets")
}

model CoreAuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String?  @map("tenant_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  moduleCode     String   @map("module_code") @db.VarChar(64)
  action         String   @db.VarChar(160)
  entityType     String   @map("entity_type") @db.VarChar(128)
  entityId       String?  @map("entity_id") @db.VarChar(128)
  outcome        String   @default("success") @db.VarChar(32)
  sensitivity    String   @default("standard") @db.VarChar(32)
  previousValues Json?    @map("previous_values")
  newValues      Json?    @map("new_values")
  metadata       Json?
  correlationId  String?  @map("correlation_id") @db.Uuid
  requestId      String?  @map("request_id") @db.VarChar(128)
  ipAddress      String?  @map("ip_address") @db.VarChar(64)
  userAgent      String?  @map("user_agent") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       CoreTenant?       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization CoreOrganization? @relation(fields: [tenantId, organizationId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade)
  actorUser    CoreUser?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId, organizationId, createdAt, id])
  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([moduleCode, action, createdAt])
  @@index([entityType, entityId])
  @@index([correlationId])
  @@map("core_audit_logs")
}

model CoreExternalReference {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String?  @map("tenant_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  domainCode     String   @map("domain_code") @db.VarChar(64)
  entityType     String   @map("entity_type") @db.VarChar(128)
  entityId       String   @map("entity_id") @db.VarChar(128)
  externalSystem String   @map("external_system") @db.VarChar(128)
  externalKey    String   @map("external_key") @db.VarChar(255)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       CoreTenant?       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization CoreOrganization? @relation(fields: [tenantId, organizationId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, organizationId, externalSystem, externalKey], map: "core_external_refs_scope_system_key_key")
  @@index([tenantId, organizationId, domainCode, entityType, entityId], map: "core_external_refs_scope_entity_idx")
  @@index([tenantId, organizationId, id], map: "core_external_refs_scope_cursor_idx")
  @@map("core_external_references")
}
