{
  "name": "@newax/api",
  "version": "0.0.0",
  "private": true,
  "description": "NEWAX business infrastructure API.",
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.11.0"
  },
  "scripts": {
    "build": "nest build",
    "build:foundation": "pnpm --filter @newax/organizations build && pnpm --filter @newax/people build && pnpm --filter @newax/memberships build && pnpm --filter @newax/access-control build && pnpm --filter @newax/users build && pnpm --filter @newax/auth build",
    "db:format": "prisma format",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:validate": "prisma validate",
    "dev": "nest start --watch",
    "prebuild": "pnpm run build:foundation && pnpm run db:generate",
    "pretest": "pnpm run build:foundation && pnpm run db:generate",
    "pretest:coverage": "pnpm run build:foundation && pnpm run db:generate",
    "pretest:watch": "pnpm run build:foundation && pnpm run db:generate",
    "pretypecheck": "pnpm run build:foundation && pnpm run db:generate",
    "start": "node dist/main.js",
    "start:debug": "nest start --debug --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "pnpm run typecheck:src && pnpm run typecheck:test",
    "typecheck:src": "tsc --project tsconfig.json --noEmit",
    "typecheck:test": "tsc --project tsconfig.spec.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@newax/access-control": "workspace:*",
    "@newax/auth": "workspace:*",
    "@newax/memberships": "workspace:*",
    "@newax/organizations": "workspace:*",
    "@newax/people": "workspace:*",
    "@newax/users": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/testing": "11.1.28",
    "@types/node": "24.10.1",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "prisma": "7.8.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
